{
  "hosting": {
    "site": "uwrdiary",
    "public": ".",
    "ignore": [
      "firebase.json",
      "deploy.sh",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/sw.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-store" }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
